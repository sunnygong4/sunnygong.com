  <script is:inline>
    const root = document.querySelector("[data-feather-demo]");

    if (root) {
      const stage = root.querySelector("[data-feather-stage]");
      const world = root.querySelector("[data-feather-world]");
      const feather = root.querySelector("[data-feather]");
      const shadow = root.querySelector("[data-feather-shadow]");
      const layers = Array.from(root.querySelectorAll("[data-depth]"));
      const sunHalo = root.querySelector(".feather-demo__sun-halo");
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const state = {
        start: performance.now(),
        panX: 0,
        panY: 0,
        targetX: 0,
        targetY: 0,
      };
      const introDuration = 9800;

      const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
      const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);
      const easeInOutSine = (t) => -(Math.cos(Math.PI * t) - 1) / 2;
      const mapProgress = (value, start, end) => clamp((value - start) / (end - start), 0, 1);

      const introPosition = (t, width, height) => {
        if (t < 0.34) {
          const skyT = t / 0.34;
          return {
            x: width * (0.14 + 0.56 * skyT) + Math.sin(t * Math.PI * 6.8) * 24,
            y: height * (0.18 + Math.sin(t * Math.PI * 3.2 + 0.4) * 0.028),
            rotate: -18 + Math.sin(t * Math.PI * 7.4 + 0.8) * 10,
            scale: 0.74 + skyT * 0.07,
          };
        }

        if (t < 0.82) {
          const gustT = mapProgress(t, 0.34, 0.82);
          const arc = easeInOutSine(gustT);
          return {
            x:
              width * (0.70 - 0.3 * arc) +
              Math.sin(gustT * Math.PI * 5.8 + 0.2) * (22 - gustT * 8),
            y:
              height * (0.2 + 0.42 * easeOutCubic(gustT)) +
              Math.cos(gustT * Math.PI * 7.2) * (18 - gustT * 10),
            rotate: -6 + Math.sin(gustT * Math.PI * 8.8 + 0.9) * 15,
            scale: 0.81 + gustT * 0.13,
          };
        }

        const settleT = mapProgress(t, 0.82, 1);
        return {
          x: width * (0.4 + settleT * 0.04) + Math.sin(settleT * Math.PI * 5.2) * 8,
          y: height * (0.62 + settleT * 0.05) + Math.cos(settleT * Math.PI * 4.4) * 7,
          rotate: 6 + Math.sin(settleT * Math.PI * 4.8 + 0.6) * 6,
          scale: 0.94 + settleT * 0.05,
        };
      };

      const restingPosition = (time, width, height) => {
        const x = width * 0.44 + Math.sin(time * 0.00052) * 15 + Math.cos(time * 0.0011) * 5;
        const y = height * 0.67 + Math.cos(time * 0.00068) * 11 + Math.sin(time * 0.0014) * 4;
        const rotate = 4 + Math.sin(time * 0.001) * 5 + Math.cos(time * 0.0006) * 2;
        return { x, y, rotate, scale: 0.99 };
      };

      stage.addEventListener("pointermove", (event) => {
        const rect = stage.getBoundingClientRect();
        const x = (event.clientX - rect.left) / rect.width - 0.5;
        const y = (event.clientY - rect.top) / rect.height - 0.5;
        state.targetX = clamp(x, -0.5, 0.5);
        state.targetY = clamp(y, -0.5, 0.5);
      });

      stage.addEventListener("pointerleave", () => {
        state.targetX = 0;
        state.targetY = 0;
      });

      const render = (time) => {
        const reduced = prefersReducedMotion.matches;
        const rect = stage.getBoundingClientRect();
        const width = rect.width;
        const height = rect.height;
        const elapsed = time - state.start;
        const progress = reduced ? 1 : clamp(elapsed / introDuration, 0, 1);
        const inIntro = !reduced && progress < 1;
        const cityProgress = reduced ? 1 : easeOutCubic(mapProgress(progress, 0.32, 0.82));

        state.panX += (state.targetX - state.panX) * 0.055;
        state.panY += (state.targetY - state.panY) * 0.055;

        const position = inIntro ? introPosition(progress, width, height) : restingPosition(time, width, height);
        const worldTranslateX = state.panX * 20;
        const worldTranslateY = state.panY * 12;
        const worldScale = 1.01 + cityProgress * 0.016;

        world.style.transform = `translate3d(${worldTranslateX.toFixed(2)}px, ${worldTranslateY.toFixed(2)}px, 0) scale(${worldScale.toFixed(4)})`;

        if (sunHalo) {
          sunHalo.style.opacity = (0.82 - cityProgress * 0.62).toFixed(3);
          sunHalo.style.transform = `translate3d(${(state.panX * 12).toFixed(2)}px, ${(state.panY * 7).toFixed(2)}px, 0) scale(${(1 + progress * 0.06).toFixed(4)})`;
        }

        for (const layer of layers) {
          const depth = Number(layer.dataset.depth || 0);
          const layerName = layer.dataset.layer || "";
          const layerX = state.panX * depth * 70;
          const layerY = state.panY * depth * 36;
          let revealY = 0;
          let revealScale = 1;
          let opacity = 1;

          if (layerName === "far") {
            opacity = 0.28 + cityProgress * 0.42;
            revealY = (1 - cityProgress) * 18;
          } else if (layerName === "city") {
            opacity = cityProgress;
            revealY = (1 - cityProgress) * 180;
            revealScale = 0.86 + cityProgress * 0.14;
          } else if (layerName === "front") {
            opacity = cityProgress * 0.86;
            revealY = (1 - cityProgress) * 96;
            revealScale = 0.92 + cityProgress * 0.08;
          }

          layer.style.opacity = opacity.toFixed(3);
          layer.style.transform = `translate3d(${layerX.toFixed(2)}px, ${(layerY + revealY).toFixed(2)}px, 0) scale(${revealScale.toFixed(4)})`;
        }

        const featherX = position.x + state.panX * 18;
        const featherY = position.y + state.panY * 12;
        feather.style.transform = `translate3d(${featherX.toFixed(2)}px, ${featherY.toFixed(2)}px, 0) rotate(${position.rotate.toFixed(2)}deg) scale(${position.scale.toFixed(4)})`;
        feather.style.opacity = (0.18 + progress * 0.82).toFixed(3);

        const shadowLift = clamp(mapProgress(position.y / height, 0.26, 0.82), 0, 1);
        const shadowX = featherX - 4;
        const shadowY = height * 0.79 + Math.max(-22, Math.min(18, (position.y - height * 0.62) * 0.1));
        const shadowScaleX = 0.58 + shadowLift * 0.42;
        const shadowScaleY = 0.18 + shadowLift * 0.08;
        shadow.style.transform = `translate3d(${shadowX.toFixed(2)}px, ${shadowY.toFixed(2)}px, 0) scale(${shadowScaleX.toFixed(3)}, ${shadowScaleY.toFixed(3)})`;
        shadow.style.opacity = (shadowLift * 0.22).toFixed(3);

        root.dataset.phase = inIntro ? "intro" : "settled";
        root.style.setProperty("--demo-progress", progress.toFixed(3));
        root.style.setProperty("--city-progress", cityProgress.toFixed(3));

        window.requestAnimationFrame(render);
      };

      window.requestAnimationFrame(render);
    }
  </script>

