---
import type { Photo } from "../data/content";
import { thumbnailFor } from "../data/images";

interface Props {
  photo: Photo;
  compact?: boolean;
  showAction?: boolean;
}

const { photo, compact = false, showAction = true } = Astro.props;
const thumbnail = thumbnailFor(photo.image);
---

<article class:list={["card", "photo-card", compact && "photo-card--compact"]}>
  <a class="photo-card__frame" href={photo.image} target="_blank" rel="noreferrer" aria-label={`Open ${photo.title} full size`}>
    <img class="card__media" src={thumbnail} alt={photo.alt} loading="lazy" decoding="async" />
  </a>
  <div class="card__body">
    <div class="card__header">
      <p class="eyebrow">{photo.collection}</p>
      <h3>{photo.title}</h3>
    </div>
    <p>{photo.blurb}</p>
    <p class="card__meta">{photo.location} · {photo.year}</p>
    <ul class="chip-list" aria-label={`${photo.title} tags`}>
      {photo.tags.map((tag) => <li>{tag}</li>)}
    </ul>
    {
      showAction && (
        <div class="card__actions">
          <a class="text-link" href={photo.image} target="_blank" rel="noreferrer">Open full frame</a>
        </div>
      )
    }
  </div>
</article>
