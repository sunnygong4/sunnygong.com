---
import { site } from "../data/site";

const pathname = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  { href: site.gallerySite, label: "Gallery", external: true },
  { href: "/projects/", label: "Projects" },
  { href: site.blogSite, label: "Writing", external: true },
  { href: "/about/", label: "About" },
];

const isActive = (item: (typeof navItems)[number]) =>
  item.external ? false : item.href === "/" ? pathname === "/" : pathname.startsWith(item.href);
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="nav-logo" href="/" aria-label={`${site.name} home`}>
      <img src={site.wordmark} alt={`${site.name} logo`} loading="eager" decoding="async" />
    </a>

    <nav class="nav" aria-label="Primary">
      {
        navItems.map((item) => (
          <a class:list={["nav__link", isActive(item) && "is-active"]} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
