---

<footer class="site-footer">
  <div class="footer-full">
    <div class="footer-full__top">
      <div class="footer-full__brand">
        <img
          src="/images/watermark-white.png"
          alt="Sunny Gong signature"
          class="footer-full__signature"
          loading="lazy"
          decoding="async"
        />
      </div>

      <nav class="footer-full__nav" aria-label="Footer navigation">
        {navItems.map((item) => (
          <a class="footer-full__nav-btn" href={item.href}>{item.label}</a>
        ))}
      </nav>

      <div class="footer-full__social">
        {socialIcons.map((item) => (
          <a
            class={`footer-full__social-btn${item.action === "wechat" ? " js-wechat-trigger" : ""}`}
            href={item.href}
            aria-label={item.label}
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={item.href.startsWith("http") ? "noreferrer" : undefined}
            title={item.label}
          >
            <Fragment set:html={item.svg} />
          </a>
        ))}
      </div>
    </div>

    <div class="footer-full__divider"></div>

    <div class="footer-full__bottom">
      <p class="footer-full__copy">&copy; {site.copyrightYear} {site.name}</p>
      <p class="footer-full__copy">{site.location}</p>
    </div>
  </div>

  <!-- WeChat QR Modal -->
  <div class="wechat-modal" data-wechat-modal hidden>
    <div class="wechat-modal__card" data-wechat-card>
      <button class="wechat-modal__close" type="button" data-wechat-close aria-label="Close">&times;</button>
      <img src="/images/wechat-qr.jpg" alt="Scan to add Sunny Gong on WeChat" class="wechat-modal__qr" />
      <p class="wechat-modal__label">Scan to add me on WeChat</p>
      <p class="wechat-modal__id">{site.contact.wechat}</p>
    </div>
  </div>
</footer>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const trigger = document.querySelector(".js-wechat-trigger");
    const modal = document.querySelector("[data-wechat-modal]");
    const card = modal?.querySelector("[data-wechat-card]");
    const closeBtn = modal?.querySelector("[data-wechat-close]");

    if (!trigger || !modal || !card || !closeBtn) return;

    const open = () => {
      modal.hidden = false;
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = "";
    };

    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      open();
    });

    closeBtn.addEventListener("click", close);

    modal.addEventListener("click", (e) => {
      if (e.target === modal) close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.hidden) close();
    });
  });
</script>
