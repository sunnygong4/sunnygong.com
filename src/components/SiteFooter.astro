---
import { site } from "../data/site";

const footerGroups = [
  {
    title: "Reach out",
    items: [
      { meta: "Personal", label: site.email, href: `mailto:${site.email}` },
      { meta: "School", label: site.contact.schoolEmail, href: `mailto:${site.contact.schoolEmail}` },
      { meta: "Profile", label: "LinkedIn", href: site.contact.linkedin },
      { meta: "Instagram", label: `@${site.contact.instagramHandle}`, href: site.contact.instagramUrl },
    ],
  },
  {
    title: "Explore",
    items: [
      { label: "Home", href: "/" },
      { label: "Projects", href: "/projects/" },
      { label: "Gallery", href: site.gallerySite },
      { label: "About", href: "/about/" },
      { label: "Blog", href: site.blogSite },
    ],
  },
  {
    title: "Elsewhere",
    items: [
      { label: "image.sunnygong.com", href: site.gallerySite },
      { label: "blog.sunnygong.com", href: site.blogSite },
    ],
  },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="footer__top">
      <div class="footer__intro">
        <p class="eyebrow">Keep in touch</p>
        <h2 class="footer__title">Email is still the best way to start.</h2>
        <p class="footer__copy">
          If you want the resume version, project context, or the longer story behind the work, reach out and I will
          point you to the right place.
        </p>
        <div class="card__actions">
          <a class="button button--primary" href={`mailto:${site.email}`}>Email {site.name}</a>
          <a class="text-link" href={`mailto:${site.contact.schoolEmail}`}>Use school email instead</a>
        </div>
      </div>

      <nav class="footer__nav-grid" aria-label="Footer">
        {
          footerGroups.map((group) => (
            <section class="footer__group">
              <h3>{group.title}</h3>
              <ul>
                {group.items.map((item) => (
                  <li>
                    {item.meta && <span class="footer__item-meta">{item.meta}</span>}
                    <a href={item.href}>{item.label}</a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </nav>
    </div>

    <div class="footer__secondary" aria-label="Additional contact methods">
      <a class="footer__secondary-link" href={site.contact.phoneHref}>Phone: {site.contact.phone}</a>
      <p class="footer__secondary-item">Discord: {site.contact.discord}</p>
      <p class="footer__secondary-item">WeChat: {site.contact.wechat}</p>
    </div>

    <div class="footer__bottom">
      <p class="footer__meta">{site.location}</p>
      <p class="footer__meta">&copy; {site.copyrightYear} {site.name}</p>
    </div>
  </div>
</footer>
