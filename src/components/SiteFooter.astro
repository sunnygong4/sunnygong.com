---
import { site, socialLinks } from "../data/site";

const navItems = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects/" },
  { label: "Gallery", href: site.gallerySite },
  { label: "Writing", href: site.blogSite },
  { label: "About", href: "/about/" },
];

const contactButtons = [
  { label: "Email me", href: `mailto:${site.email}`, primary: true },
  { label: "LinkedIn", href: site.contact.linkedin, primary: false },
  { label: "Instagram", href: site.contact.instagramUrl, primary: false },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <img src={site.wordmark} alt={site.name} class="footer__wordmark" loading="lazy" decoding="async" />
        <p class="footer__tagline">
          Computer engineering, photography, and the small experiments that still deserve a page.
        </p>
      </div>

      <nav class="footer__nav" aria-label="Footer navigation">
        <h3 class="footer__heading">Navigate</h3>
        <div class="footer__nav-buttons">
          {navItems.map((item) => (
            <a class="footer__nav-btn" href={item.href}>{item.label}</a>
          ))}
        </div>
      </nav>
    </div>

    <div class="footer__cta">
      <div class="footer__cta-text">
        <h2 class="footer__title">Have a question or want to work together?</h2>
        <p class="footer__copy">
          I'm always happy to chat about projects, photography, or collaboration opportunities.
          Drop me a line and I'll get back to you.
        </p>
      </div>
      <div class="footer__cta-actions">
        {contactButtons.map((btn) => (
          <a class={`button ${btn.primary ? "button--primary" : "button--secondary"}`} href={btn.href}>
            {btn.label}
          </a>
        ))}
      </div>
    </div>

    <div class="footer__details">
      <div class="footer__detail-group">
        <h3 class="footer__heading">Contact</h3>
        <div class="footer__detail-items">
          <a class="footer__detail-btn" href={`mailto:${site.email}`}>{site.email}</a>
          <a class="footer__detail-btn" href={`mailto:${site.contact.schoolEmail}`}>{site.contact.schoolEmail}</a>
          <a class="footer__detail-btn" href={site.contact.phoneHref}>{site.contact.phone}</a>
        </div>
      </div>
      <div class="footer__detail-group">
        <h3 class="footer__heading">Elsewhere</h3>
        <div class="footer__detail-items">
          <a class="footer__detail-btn" href={site.gallerySite}>image.sunnygong.com</a>
          <a class="footer__detail-btn" href={site.blogSite}>blog.sunnygong.com</a>
        </div>
      </div>
      <div class="footer__detail-group">
        <h3 class="footer__heading">Also on</h3>
        <div class="footer__detail-items">
          <span class="footer__detail-chip">Discord: {site.contact.discord}</span>
          <span class="footer__detail-chip">WeChat: {site.contact.wechat}</span>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__meta">&copy; {site.copyrightYear} {site.name}</p>
      <p class="footer__meta">{site.location}</p>
    </div>
  </div>
</footer>
