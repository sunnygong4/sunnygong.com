---
import type { Post } from "../data/content";
import { thumbnailFor } from "../data/images";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const publishLabel = new Intl.DateTimeFormat("en-CA", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(post.publishDate);
const thumbnail = thumbnailFor(post.hero);
---

<article class="card post-card">
  <img class="card__media" src={thumbnail} alt="" loading="lazy" decoding="async" />
  <div class="card__body">
    <div class="card__header">
      <p class="eyebrow">{post.topic}</p>
      <h3>{post.title}</h3>
    </div>
    <p>{post.summary}</p>
    <p class="card__meta">{publishLabel}</p>
    <div class="card__actions">
      <a class="text-link" href={`/writing/${post.slug}/`}>Read note</a>
    </div>
  </div>
</article>
