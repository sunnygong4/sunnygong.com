---
import type { Project } from "../data/content";
import { thumbnailFor } from "../data/images";

interface Props {
  project: Project;
  publicHref?: string;
  writeupHref?: string;
}

const { project, publicHref, writeupHref } = Astro.props;
const detailHref = `/projects/${project.slug}/`;
const detailLabel = project.kind === "case-study" ? "See details" : "Project brief";
const thumbnail = thumbnailFor(project.hero);
---

<article class="card project-card">
  <img class="card__media" src={thumbnail} alt="" loading="lazy" decoding="async" />
  <div class="card__body">
    <div class="card__header">
      <p class="eyebrow">{project.kind === "case-study" ? "Case study" : "Linked project"}</p>
      <h3>{project.title}</h3>
    </div>
    <p>{project.summary}</p>
    <p class="card__meta">Status: {project.status}</p>
    <ul class="chip-list" aria-label={`${project.title} stack`}>
      {project.stack.map((item) => <li>{item}</li>)}
    </ul>
    <div class="card__actions">
      <a class="button button--secondary" href={detailHref}>{detailLabel}</a>
      {project.repo && <a class="text-link" href={project.repo} target="_blank" rel="noreferrer">GitHub</a>}
      {publicHref && <a class="text-link" href={publicHref}>Open project site</a>}
      {writeupHref && project.kind === "external-link" && <a class="text-link" href={writeupHref}>Write-up</a>}
    </div>
  </div>
</article>
