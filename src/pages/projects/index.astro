---
import PageIntro from "../../components/PageIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/content";
import { getProjectLink } from "../../data/site";

const featuredProjects = projects.filter((project) => project.featured);
const archiveProjects = projects.filter((project) => !project.featured);
const getDetailHref = (project) => `/projects/${project.slug}/`;
const getPublicHref = (project) => project.href ?? getProjectLink(project.slug);
---

<BaseLayout title="Projects" description="A prioritized archive of Sunny Gong's projects, systems, and experiments.">
  <PageIntro
    eyebrow="Projects"
    title="A cleaner project archive with the strongest builds up front"
    lede="This page puts the projects I would point to first at the top, then keeps the rest of the work close by so someone can click in, skim the details, and understand what each build was trying to do."
  />

  <section class="section">
    <div class="section__head section__head--split">
      <div>
        <p class="eyebrow">Featured projects</p>
        <h2>The work I would send first</h2>
      </div>
      <p class="section__lede">
        These are the more substantial builds, systems, and challenge pieces that do the best job of showing how I think through product, infrastructure, and engineering tradeoffs.
      </p>
    </div>

    <div class="project-spotlights">
      {
        featuredProjects.map((project) => (
          <article class="project-spotlight">
            <div class="project-spotlight__top">
              <div class="project-spotlight__title">
                <p class="eyebrow">Featured</p>
                <h2>
                  <a href={getDetailHref(project)}>{project.title}</a>
                </h2>
                <p class="project-spotlight__summary">{project.summary}</p>
              </div>
              <p class="project-spotlight__status">{project.status}</p>
            </div>

            <ul class="chip-list" aria-label={`${project.title} stack`}>
              {project.stack.map((item) => <li>{item}</li>)}
            </ul>

            <div class="card__actions">
              <a class="button button--secondary" href={getDetailHref(project)}>Read project</a>
              {getPublicHref(project) && <a class="text-link" href={getPublicHref(project)}>Open site</a>}
              {project.repo && <a class="text-link" href={project.repo}>Source code</a>}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="section__head section__head--split">
      <div>
        <p class="eyebrow">Project archive</p>
        <h2>Everything else, still easy to click through</h2>
      </div>
      <p class="section__lede">
        Smaller systems, earlier prototypes, and course-heavy builds still matter. They just read better as a straightforward list than as another wall of cards.
      </p>
    </div>

    <div class="project-archive">
      {
        archiveProjects.map((project, index) => (
          <article class="project-row">
            <div class="project-row__main">
              <p class="project-row__index">{String(index + 1).padStart(2, "0")}</p>
              <div class="project-row__copy">
                <h3>
                  <a href={getDetailHref(project)}>{project.title}</a>
                </h3>
                <p>{project.summary}</p>
              </div>
            </div>

            <div class="project-row__meta">
              <p class="project-row__status">{project.status}</p>
              <ul class="project-row__stack" aria-label={`${project.title} stack`}>
                {project.stack.slice(0, 4).map((item) => <li>{item}</li>)}
              </ul>
              <div class="project-row__links">
                <a class="project-row__link" href={getDetailHref(project)}>Read project</a>
                {getPublicHref(project) && <a class="project-row__link" href={getPublicHref(project)}>Open site</a>}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .project-spotlights,
  .project-archive {
    display: grid;
    gap: 1rem;
  }

  .project-spotlight,
  .project-row {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }

  .project-spotlight__top {
    display: flex;
    flex-wrap: wrap;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-spotlight__title {
    display: grid;
    gap: 0.55rem;
    max-width: 46rem;
  }

  .project-spotlight__title h2 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
  }

  .project-spotlight__title a,
  .project-row__copy a {
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  .project-spotlight__summary,
  .project-row__copy p {
    color: var(--muted);
  }

  .project-spotlight__status,
  .project-row__status,
  .project-row__index {
    font-family: var(--mono);
    color: #f5df9d;
  }

  .project-row {
    grid-template-columns: minmax(0, 1.4fr) minmax(16rem, 0.8fr);
    align-items: start;
  }

  .project-row__main,
  .project-row__copy,
  .project-row__meta {
    display: grid;
    gap: 0.65rem;
  }

  .project-row__main {
    grid-template-columns: auto minmax(0, 1fr);
    align-items: start;
  }

  .project-row__index {
    min-width: 2.25rem;
    font-size: 0.94rem;
    padding-top: 0.25rem;
  }

  .project-row__copy h3 {
    font-size: 1.45rem;
  }

  .project-row__meta {
    justify-items: end;
  }

  .project-row__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: flex-end;
  }

  .project-row__stack li {
    padding: 0.42rem 0.75rem;
    border-radius: var(--radius-sm);
    background: rgba(255, 248, 238, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: var(--muted);
    font-size: 0.92rem;
  }

  .project-row__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1rem;
    justify-content: flex-end;
  }

  .project-row__link {
    color: var(--accent-cool);
    font-family: var(--mono);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media (max-width: 820px) {
    .project-row {
      grid-template-columns: 1fr;
    }

    .project-row__meta,
    .project-row__stack,
    .project-row__links {
      justify-items: start;
      justify-content: flex-start;
    }
  }
</style>
