---
import PageIntro from "../../components/PageIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
---

<BaseLayout title="Writing" description="Longer writing is moving to the proposed Sunny Gong blog.">
  <PageIntro
    eyebrow="Writing"
    title="Long-form notes are moving to the blog"
    lede="The future home for essays, project notes, and slower write-ups is blog.sunnygong.com. This page is just the handoff while that space is still being built."
  />

  <section class="section">
    <div class="section__head section__head--split">
      <div>
        <p class="eyebrow">Proposed blog</p>
        <h2>The next writing home is {new URL(site.blogSite).host}</h2>
      </div>
      <p class="section__lede">
        The portfolio can stay focused on projects and photography, while the deeper essays and process notes move into a separate blog when it is ready.
      </p>
    </div>

    <div class="home-split">
      <div class="home-panel">
        <p>
          Longer writing still matters, but it probably deserves its own room instead of sitting in the middle of the portfolio navigation forever.
        </p>
        <p>
          The plan is for future case studies, essays, and slower reflections to live at{" "}
          <a class="text-link" href={site.blogSite}>blog.sunnygong.com</a>.
        </p>
      </div>

      <div class="home-panel home-panel--accent">
        <p class="eyebrow">For now</p>
        <ul class="home-list">
          <li>The blog domain is linked now, even though the full build is still in progress.</li>
          <li>The main portfolio stays cleaner and more focused on the work itself.</li>
          <li>Existing older writing can stay in the background until the separate blog is ready.</li>
        </ul>
        <div class="card__actions">
          <a class="button button--secondary" href={site.blogSite}>Visit the proposed blog</a>
          <a class="text-link" href="/projects/">Back to projects</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
