---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import { site } from "../data/site";
---

<BaseLayout title="About" description="About Sunny Gong and the thinking behind this portfolio.">
  <PageIntro
    eyebrow="About"
    title="Computer engineering, personal tools, and photography in one place"
    lede="I like building things that are useful, clear, and still a little personal. This site is where the software work, the photos, and the thinking behind them can live together without pretending they are separate interests."
  />

  <section class="section">
    <div class="section__head">
      <p class="eyebrow">Why this site exists</p>
      <h2>More context than a resume can hold</h2>
    </div>
    <div class="prose">
      <p>
        I wanted one place that could show how I think, not just what I have touched. That means project write-ups,
        smaller experiments, and photography all share the same space because they genuinely inform each other.
      </p>
      <p>
        Computer engineering gives me the systems mindset. Photography gives me patience, framing, and attention to
        detail. Together they shape how I build interfaces and how I explain the work behind them.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section__head">
      <p class="eyebrow">What I care about</p>
      <h2>The kind of work I keep coming back to</h2>
    </div>
    <div class="grid grid--cards">
      <article class="stat-card">
        <strong>Clear systems</strong>
        <p>I like software that is dependable underneath and easy to move through on the surface.</p>
      </article>
      <article class="stat-card">
        <strong>Personal interfaces</strong>
        <p>I care about tools and sites that feel intentional instead of interchangeable or overly polished.</p>
      </article>
      <article class="stat-card">
        <strong>Observation</strong>
        <p>Photography keeps teaching me pacing, composition, and detail, and that carries directly into product work.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section__head section__head--split">
      <div>
        <p class="eyebrow">Contact</p>
        <h2>The easiest ways to reach me</h2>
      </div>
      <p class="section__lede">
        Email is still the best first contact if you want the resume version, project context, or just the longer story
        behind the work.
      </p>
    </div>

    <div class="home-split">
      <div class="home-panel">
        <p>
          I am still turning projects into clearer case studies, keeping this site current, and building out the photo
          side at <a class="text-link" href={site.gallerySite}>image.sunnygong.com</a>.
        </p>
        <p>
          The best way to start is my personal email. If school context or public profiles make more sense, those are
          here too.
        </p>
        <div class="card__actions">
          <a class="button button--secondary" href={`mailto:${site.email}`}>Email {site.name}</a>
          <a class="text-link" href={site.contact.linkedin}>LinkedIn</a>
        </div>
      </div>

      <div class="home-panel home-panel--accent">
        <dl class="contact-list">
          <div class="contact-list__item">
            <dt>Personal email</dt>
            <dd><a class="text-link" href={`mailto:${site.email}`}>{site.email}</a></dd>
          </div>
          <div class="contact-list__item">
            <dt>School email</dt>
            <dd><a class="text-link" href={`mailto:${site.contact.schoolEmail}`}>{site.contact.schoolEmail}</a></dd>
          </div>
          <div class="contact-list__item">
            <dt>LinkedIn</dt>
            <dd><a class="text-link" href={site.contact.linkedin}>fangxu-gong-7b9b26221</a></dd>
          </div>
          <div class="contact-list__item">
            <dt>Instagram</dt>
            <dd><a class="text-link" href={site.contact.instagramUrl}>@{site.contact.instagramHandle}</a></dd>
          </div>
          <div class="contact-list__item contact-list__item--soft">
            <dt>Phone</dt>
            <dd><a class="text-link" href={site.contact.phoneHref}>{site.contact.phone}</a></dd>
          </div>
          <div class="contact-list__item contact-list__item--soft">
            <dt>Discord</dt>
            <dd>{site.contact.discord}</dd>
          </div>
          <div class="contact-list__item contact-list__item--soft">
            <dt>WeChat</dt>
            <dd>{site.contact.wechat}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>
</BaseLayout>
